  "info": {
    "_postman_id": "41a16009-b1c0-41db-a2ab-783f7d5c151d",
    "name": "Heap Server-Side API",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json",
    "description": {
      "content": "Heap's server-side APIs let backend services send events, attach\nidentities, and update user/account properties in a Heap workspace.\nAll requests are JSON POSTs against https://heapanalytics.com. The\nworkspace is identified via the `app_id` (environment ID) included in\neach request body.\n\n\nContact Support:\n Name: Heap Developers",
      "type": "text/plain"
    }
  }
