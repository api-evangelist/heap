    {
      "id": "be0d6e1e-34c8-4dc3-a59f-ee4143db5240",
      "name": "Add account properties",
      "request": {
        "name": "Add account properties",
        "description": {
          "content": "Update properties on one or more accounts. Either provide a single\n`account_id`/`properties` pair or an `accounts` array for bulk updates.\nAccount configuration (or Salesforce integration) must be enabled for\nthe workspace.\n",
          "type": "text/plain"
        },
        "url": {
          "path": [
            "api",
            "add_account_properties"
          ],
          "host": [
            "{{baseUrl}}"
          ],
          "query": [],
          "variable": []
        },
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "method": "POST",
        "auth": null,
        "body": {
          "mode": "raw",
          "raw": "{\n  \"app_id\": \"<integer>\",\n  \"account_id\": \"<string>\",\n  \"properties\": {\n    \"key_0\": \"<string>\",\n    \"key_1\": \"<string>\",\n    \"key_2\": \"<string>\",\n    \"key_3\": \"<string>\"\n  },\n  \"accounts\": [\n    {\n      \"account_id\": \"<string>\",\n      \"properties\": {\n        \"key_0\": \"<string>\",\n        \"key_1\": \"<string>\"\n      }\n    },\n    {\n      \"account_id\": \"<string>\",\n      \"properties\": {\n        \"key_0\": \"<string>\",\n        \"key_1\": \"<string>\"\n      }\n    }\n  ]\n}",
          "options": {
            "raw": {
              "language": "json"
            }
          }
        }
